# =============================================================================
# Dautuu — environment variables
# Zkopíruj do .env a vyplň hodnoty. Nikdy necommituj .env do gitu!
# =============================================================================

# -----------------------------------------------------------------------------
# Databáze — PostgreSQL
# -----------------------------------------------------------------------------

# Varianta A: PostgreSQL v kontejneru (docker-compose.yml)
#   DATABASE_URL se nastavuje automaticky z proměnných níže.
POSTGRES_USER=dautuu
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=dautuu

# Varianta B: PostgreSQL na hostu (docker-compose.host-db.yml)
#   Odkomentuj a uprav DATABASE_URL, ostatní POSTGRES_* nejsou potřeba.
#   host.docker.internal → hostitel z pohledu kontejneru
# DATABASE_URL=postgresql+asyncpg://dautuu:heslo@host.docker.internal:5432/dautuu

# -----------------------------------------------------------------------------
# JWT Auth
# -----------------------------------------------------------------------------
# Vygeneruj silný klíč: openssl rand -hex 32
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 dní

# -----------------------------------------------------------------------------
# LLM providers
# -----------------------------------------------------------------------------

# Together.ai (primární) — https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# OpenAI (volitelné) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (volitelné) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Ollama (volitelné, lokální) — URL kde běží Ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434

# -----------------------------------------------------------------------------
# Embeddingy
# -----------------------------------------------------------------------------
# Provider pro embeddingy: together | openai | ollama
EMBEDDING_PROVIDER=together
# Model pro embeddingy
EMBEDDING_MODEL=togethercomputer/m2-bert-80M-8k-retrieval

# -----------------------------------------------------------------------------
# CORS — povolené origins pro frontend
# -----------------------------------------------------------------------------
# Čárkou oddělené origins, např.: http://localhost:5173,https://app.example.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
